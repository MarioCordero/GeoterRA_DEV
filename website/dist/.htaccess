<Directory /home/proyecto/GeoterRA_DEV/website/dist>
    Options Indexes FollowSymLinks
    AllowOverride All
    Require all granted
    Options -Indexes

    RewriteEngine On
    RewriteBase /

    # If the request is for a real file or directory, serve it
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Otherwise, fallback to index.html for SPA
    RewriteRule ^ index.html [L]
</Directory>