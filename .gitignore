# --- Gradle build cache and outputs ---
.gradle/
build/
**/build/
out/
captures/

# --- Local configuration files ---
local.properties
.gradle/
gradle-app.setting
.gradle-build-cache/

# --- Android Studio configuration (user-specific) ---
.idea/
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/libraries/
.idea/misc.xml
.idea/caches/
.idea/modules.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
