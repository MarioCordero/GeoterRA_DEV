# --- Log files ---
*.log

# --- Keystore files (never commit secrets) ---
*.jks
*.keystore
*.pem
*.key
*.p12

# --- Generated files by Android Studio ---
*.apk
*.ap_
*.aab
*.dex
*.class

# --- ProGuard / R8 ---
proguard/
*.mapping
*.dump
*.seeds
*.usage
*.log

# --- Gradle wrapper ---
# The wrapper JAR and properties are needed for consistent builds,
# but avoid committing temporary Gradle caches.
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# --- Environment-specific ---
*.swp
*.swo
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# --- IntelliJ IDEA cache directories ---
.idea/sonarlint/
.idea/httpRequests/
.idea/shelf/
.idea/other.xml

# --- Kotlin-specific build outputs ---
*.kotlin_module
*.kotlin_metadata
*.kotlin_builtins

# --- Generated JNI / CMake outputs ---
cmake-build-*/

# --- Test outputs ---
/test-results/
/coverage/
/reports/

# --- Jetpack Compose compiler caches ---
**/.compose-cache/
**/.kotlin/compose-cache/

# --- Miscellaneous ---
*.hprof
*.orig
*.rej

# --- Firebase / Google Services secrets ---
google-services.json
