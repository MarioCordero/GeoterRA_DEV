<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         failOnRisky="true"
         failOnWarning="true"
         beStrictAboutOutputDuringTests="true"
         beStrictAboutTestsThatDoNotTestAnything="false"
         displayDetailsOnIncompleteTests="true"
         displayDetailsOnSkippedTests="true">

    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit/</directory>
        </testsuite>
        <testsuite name="DTO">
            <directory>tests/Unit/DTO/</directory>
        </testsuite>
        <testsuite name="Services">
            <directory>tests/Unit/Services/</directory>
        </testsuite>
        <testsuite name="Repositories">
            <directory>tests/Unit/Repositories/</directory>
        </testsuite>
        <testsuite name="Http">
            <directory>tests/Unit/Http/</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory suffix=".php">src/</directory>
        </include>
        <exclude>
            <directory>src/Core/</directory>
            <directory>src/Router/</directory>
        </exclude>
    </source>

    <coverage>
        <report>
            <html outputDirectory="coverage/" />
            <text outputFile="php://stdout" showUncoveredFiles="true" />
        </report>
    </coverage>

    <php>
        <ini name="error_reporting" value="-1"/>
        <ini name="display_errors" value="On"/>
        <ini name="display_startup_errors" value="On"/>
        <ini name="default_timezone" value="UTC"/>
        <env name="TEST_ENV" value="test"/>
    </php>

</phpunit>
